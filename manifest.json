{
  "manifest_version": 3,
  "name": "X Likes Harvester",
  "version": "1.0.0",
  "description": "Extract likers from X posts, export CSV, send DMs via Twitter API v2",
  "permissions": ["storage", "activeTab", "scripting", "identity"],
  "host_permissions": ["https://twitter.com/*", "https://x.com/*", "https://api.twitter.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
